# --- App ---
APP_NAME=AI Personal Finance & Expense Tracker
ENV=development
DEBUG=True

# --- Database ---
# SQLite (default, dev)
DATABASE_URL=sqlite:///./finance_tracker.db
# PostgreSQL (production) example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/finance_tracker

# --- Auth / JWT ---
SECRET_KEY=change-this-to-a-random-64-char-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AI (optional; app runs with rule-based fallback if unset) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_PROVIDER=none   # options: openai | gemini | none

# --- Misc ---
DEFAULT_CURRENCY=INR
BACKEND_URL=http://localhost:8000
